# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# raw photo originals — keep the raw/ folders for visibility, but never commit
# heic source files (they don't render in browsers and bloat the repo). run
# `npm run images` to produce the committed web-ready .jpg versions.
*.heic
*.HEIC
*.heif
*.HEIF

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
